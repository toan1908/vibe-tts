{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/assets/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "dist/$1"
    }
  ],
  "functions": {
    "server/server.js": {
      "maxDuration": 60
    }
  },
  "outputDirectory": "dist"
}
